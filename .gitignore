# Secrets — never commit (.env.example documents the shape)
.env

# K8s real secrets — only secret.example.yaml (placeholders) is committed (T-11-10 / V14).
# Copy it to secret.yaml with real values for a live deploy; that file stays local.
infra/k8s/**/secret.yaml
infra/k8s/**/secret.*.local.yaml

# Node
node_modules/
.next/

# Python
__pycache__/
.venv/
*.pyc
.pytest_cache/

# Test artifacts
test-results/
playwright-report/

# Local run logs — transient process output, never source (alembic/uvicorn/verify runs)
*.log

# Local-only Claude/editor settings (machine-specific, not shared config)
.claude/

# Generated per-app test repos — platform output, not platform source
# (keep the README that documents the directory's purpose)
workspaces/*
!workspaces/README.md
