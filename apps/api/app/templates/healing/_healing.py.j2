class HealFailed(Exception):
    """Raised when heal() cannot auto-heal (quarantine / fail_as_defect). The spec then fails
    naturally on the raise — assertions are NEVER weakened (HEAL-02 / D-04)."""


# Thresholds default to the plan-01 starting bands; the conftest may override via env so the
# whole spec stays config-tunable like settings.heal_high_threshold / heal_med_threshold.
def _env_float(name: str, default: float) -> float:
    try:
        return float(os.environ.get(name, "") or default)
    except (TypeError, ValueError):
        return default


# Defaults MIRROR settings.heal_high_threshold / heal_med_threshold (config.py) — the QUAL-02
# mutation-harness-tuned bands. The compressed geometry/DOM-only confidence scale tops out ~0.41
# for real benign drift, so the in-spec layer must default to the same 0.15/0.10 production bands
# (overridable via env) or it would never auto-heal when run without explicit thresholds.
HEAL_HIGH = _env_float("HEAL_HIGH_THRESHOLD", 0.15)
HEAL_MED = _env_float("HEAL_MED_THRESHOLD", 0.10)


def _to_selector(chain_entry: dict) -> str:
    """Map a single chain entry {strategy, value} to a Playwright selector STRING.

    Selectors use Playwright's parameterized engines (no shell, no eval of page text into code —
    T-08-05). An unknown strategy falls back to a text= match on the value.
    """
    strategy = (chain_entry or {}).get("strategy") or ""
    value = (chain_entry or {}).get("value") or ""
    if strategy == "data-testid":
        return f'[data-test="{value}"], [data-testid="{value}"]'
    if strategy == "aria-label":
        return f'[aria-label="{value}"]'
    if strategy == "role":
        return f'[role="{value}"]'
    if strategy == "text":
        return f"text={value}"
    if strategy == "xpath":
        return f"xpath={value}"
    return f"text={value}"


def _chain_to_selector(chain: list) -> str | None:
    """The selector for a chain's TOP entry, or None for an empty chain."""
    if not chain:
        return None
    return _to_selector(chain[0])


def _append_journal(out_dir, entry: dict) -> None:
    """Append ONE entry to the per-flow heal-journal JSON list at <out_dir>/heal-journal.json.

    out_dir is the spec's KNOWN per-flow workspace path (passed in by the caller) — NEVER derived
    from page/DOM text (path-traversal guard, T-08-06). File I/O only; tolerant of a missing/
    malformed existing file (starts a fresh list).
    """
    import pathlib

    journal_path = pathlib.Path(out_dir) / "heal-journal.json"
    existing: list = []
    try:
        raw = journal_path.read_text(encoding="utf-8")
        loaded = json.loads(raw)
        if isinstance(loaded, list):
            existing = loaded
    except (FileNotFoundError, ValueError, OSError):
        existing = []
    existing.append(entry)
    journal_path.parent.mkdir(parents=True, exist_ok=True)
    journal_path.write_text(json.dumps(existing, indent=2), encoding="utf-8")


def _read_candidate(page, handle) -> dict:
    """Read one live candidate's attrs / role / name / bbox / chain from a Playwright handle."""
    def _attr(name: str) -> str:
        try:
            return handle.get_attribute(name) or ""
        except Exception:  # noqa: BLE001 -- a stale handle must not crash enumeration
            return ""

    try:
        text = (handle.inner_text() or "").strip()
    except Exception:  # noqa: BLE001
        text = ""
    try:
        bbox = handle.bounding_box()
    except Exception:  # noqa: BLE001
        bbox = None
    try:
        xpath = page.evaluate(_XPATH_JS, handle)
    except Exception:  # noqa: BLE001
        xpath = ""
    try:
        tag = (handle.evaluate("e => e.tagName") or "").lower()
    except Exception:  # noqa: BLE001
        tag = ""

    role = _attr("role")
    name = _attr("aria-label") or text
    attrs = {
        "data-test": _attr("data-test"),
        "data-testid": _attr("data-testid"),
        "aria-label": _attr("aria-label"),
        "role": role,
        "text": text,
        "type": _attr("type"),
        "name": _attr("name"),
        "placeholder": _attr("placeholder"),
        "class": _attr("class"),
        "xpath": xpath,
    }
    chain = build_locator_chain(attrs)
    return {
        "tag": tag,
        "role": role,
        "name": name,
        "type": attrs["type"],
        "placeholder": attrs["placeholder"],
        "class": attrs["class"],
        "xpath": xpath,
        "bbox": bbox,
        "chain": chain,
        "attrs": attrs,
    }


def _enumerate_live_candidates(
    page, broken_chain: list, broken_attrs: dict | None = None
) -> list[dict]:
    """Enumerate live candidate elements ELEMENT-SPECIFICALLY (HEAL-01, RESEARCH Pattern 2).

    Candidates are read from the live DOM along the broken element's OWN identity tiers — the
    priority chain's LOWER tiers that may still match after a benign top-tier drift (role,
    aria-label, text) PLUS the broken element's tag (from broken_attrs). This is deliberately
    scoped to the broken element's kind: a genuinely-removed element (whose tag + lower tiers
    match nothing live) yields NO candidates, so the best selector re-validates to 0 and the
    uniqueness gate forces fail_as_defect — never a heal onto an unrelated unique element. A
    benign rename (same tag/role, only the top tier changed) still surfaces its element. Bounded
    to a small cap so a pathological page cannot blow up the heal.
    """
    broken_attrs = broken_attrs or {}
    seen_handles = []
    candidates: list[dict] = []
    selectors: list[str] = []
    for entry in broken_chain:
        strategy = (entry or {}).get("strategy") or ""
        if strategy in ("role", "aria-label", "text"):
            selectors.append(_to_selector(entry))
    tag = (broken_attrs.get("tag") or "").strip().lower()
    if tag:
        selectors.append(tag)

    for selector in selectors:
        try:
            handles = page.locator(selector).element_handles()
        except Exception:  # noqa: BLE001
            continue
        for handle in handles[:25]:
            if handle in seen_handles:
                continue
            seen_handles.append(handle)
            candidates.append(_read_candidate(page, handle))
            if len(candidates) >= 50:
                return candidates
    return candidates


def heal(
    page,
    *,
    element_key: str,
    broken_chain: list,
    broken_attrs: dict | None = None,
    broken_bbox: dict | None = None,
    history: list | None = None,
    out_dir: str,
    flow_id: str = "",
    weights: HealWeights = DEFAULT_WEIGHTS,
    high: float | None = None,
    med: float | None = None,
):
    """In-spec heal: live candidate search + score + HARD uniqueness gate + journal append.

    Returns a healed Playwright Locator ONLY for outcome == "auto_heal"; otherwise appends the
    decision to the heal-journal and raises HealFailed (the spec fails naturally — assertions are
    NEVER weakened). `out_dir` is the spec's known per-flow workspace path (never from page text).
    """
    high_t = HEAL_HIGH if high is None else high
    med_t = HEAL_MED if med is None else med
    broken_attrs = broken_attrs or {}
    history = history or []

    candidates = _enumerate_live_candidates(page, broken_chain, broken_attrs)
    scored: list[tuple[float, dict]] = []
    for cand in candidates:
        signals = score_candidate(
            cand, broken_chain, broken_attrs, broken_bbox, history
        )
        scored.append((confidence(signals, weights), cand))
    scored.sort(reverse=True, key=lambda t: t[0])
    conf, best = scored[0] if scored else (0.0, None)

    selector = _chain_to_selector(best["chain"]) if best else None
    match_count = 0
    if selector:
        try:
            match_count = page.locator(selector).count()  # HARD live re-validation
        except Exception:  # noqa: BLE001
            match_count = 0

    outcome = heal_outcome(conf, match_count, high=high_t, med=med_t)
    after_chain = best["chain"] if best else []
    _append_journal(
        out_dir,
        {
            "element_key": element_key,
            "before_chain": list(broken_chain),
            "after_chain": list(after_chain),
            "confidence": conf,
            "outcome": outcome,
            "flow_id": flow_id,
            "live_match_count": match_count,
            "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        },
    )

    if outcome == "auto_heal":
        return page.locator(selector)  # continue the test with the healed locator
    raise HealFailed(outcome)  # quarantine / fail -> the test fails (no weakened assert)
