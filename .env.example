# =============================================================================
# Environment contract — Phase 1
# Copy to .env (gitignored) and replace every <generate...> placeholder.
# This single file is shared by Docker Compose (--env-file .env) and hybrid
# host mode (D-09). Compose overrides hostnames internally (localhost -> service).
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
# Database superuser for the platform database
POSTGRES_USER=qa_platform
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=<generate>
# Database name
POSTGRES_DB=qa_platform
# Async SQLAlchemy URL (host/hybrid mode value; compose overrides host to `postgres`)
DATABASE_URL=postgresql+asyncpg://qa_platform:<password>@localhost:5432/qa_platform

# --- Redis --------------------------------------------------------------------
# Redis connection (host/hybrid mode value; compose overrides host to `redis`)
REDIS_URL=redis://localhost:6379/0

# --- Auth ---------------------------------------------------------------------
# JWT signing secret. Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=<generate: python -c "import secrets; print(secrets.token_urlsafe(64))">
# Fernet key(s) for target-credential encryption at rest. Comma-separated list
# to enable future MultiFernet rotation (first key encrypts, all keys decrypt).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TARGET_CREDENTIAL_KEY=<generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# --- Admin bootstrap (D-03: seeded on first API startup; no public signup) ----
# First admin user email
ADMIN_EMAIL=admin@local.dev
# First admin user password. Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_PASSWORD=<generate>

# --- Cookies ------------------------------------------------------------------
# false for plain-http localhost dev; flip true on any network-exposed deployment
COOKIE_SECURE=false

# --- LLM gateway (Phase 2) ------------------------------------------------------
# Provider-prefixed default model passed straight to init_chat_model (D-13).
# e.g. anthropic:claude-sonnet-4-5  OR  openai:gpt-4.1
LLM_DEFAULT_MODEL=anthropic:claude-sonnet-4-5
# Provider API keys — leave EMPTY here; supply real values only in .env (never
# committed). The app boots without them; live parity tests (Plan 03) skip when absent.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional LangSmith tracing — OFF by default; set true + a key to enable.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=

# --- LLM budget caps (Plan 02-02; PLAT-06) --------------------------------------
# Global defaults for per-call / per-run / per-day budgets on BOTH USD and token
# axes. A breach on EITHER axis in ANY scope refuses the call (BudgetExceeded)
# before spend. Per-run overrides may only TIGHTEN these (clamped to min(override,
# cap), never loosen). Daily USD exhaustion auto-trips the kill-switch.
LLM_PER_CALL_USD_CAP=1.0
LLM_RUN_USD_CAP=25.0
LLM_DAILY_USD_CAP=100.0
LLM_PER_CALL_TOKEN_CAP=200000
LLM_RUN_TOKEN_CAP=5000000
LLM_DAILY_TOKEN_CAP=20000000
# TTL (seconds) on the per-run Redis budget counters.
LLM_RUN_TTL_S=86400

# --- LLM response cache (Plan 02-03; PLAT-06, D-11/D-12) ------------------------
# TTL (seconds) on a cached deterministic (temperature==0) response. Only temp==0
# calls without no_cache are cached; an identical repeat is served for $0 and logged
# with cache_hit=true. Per-call no_cache=true opts out. Default ~24h.
LLM_CACHE_TTL_S=86400

# --- Neo4j knowledge graph (Phase 3) --------------------------------------------
# Bolt URI (host/hybrid-mode value; compose overrides host to `neo4j`). neo4j runs
# ONLY under the `graph` profile via infra/scripts/graph_mode.py (stops web first).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# CHANGE THIS — `please-change` is a flagged dev default, not a real secret.
NEO4J_PASSWORD=please-change
# Combined user/password the neo4j container reads to set initial auth.
# Keep in sync with NEO4J_USER / NEO4J_PASSWORD above (format: user/password).
NEO4J_AUTH=neo4j/please-change

# --- Stability + seeded-bug acceptance harness (Phase 6, plan 06-04; GEN-05 / D-07/D-08) ---
# STABILITY_RUNS: a generated spec is accepted only if it passes N consecutive runs (any
# flaky/non-green run rejects it). Default 3.
STABILITY_RUNS=3
# SEEDED_BUG_BASE_URL: in-cluster URL of the profile-gated saucedemo-bug build the harness
# re-runs the SAME accepted spec against — it MUST FAIL (real-breakage detection). Bring the
# bug build up with: docker compose --profile bugbuild up -d --wait saucedemo-bug
SEEDED_BUG_BASE_URL=http://saucedemo-bug:80

# --- Service URLs ---------------------------------------------------------------
# Web-tier rewrite destination (hybrid mode value; compose overrides to http://api:8000).
# Host-facing API port is 8001 (8000 is held by another local project's container);
# container-internal port remains 8000.
API_URL=http://localhost:8001

# --- Test base URLs -------------------------------------------------------------
# Base URL for Playwright UI tests
WEB_BASE_URL=http://localhost:3000
# Base URL for API functional tests
API_BASE_URL=http://localhost:8001
